# --- AI risk audit ---
# Free LLM provider via the OpenAI-compatible API. Get a key from
# https://console.groq.com (free tier, no credit card).
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
# Optional: switch to a stronger model with lower daily cap.
# LLM_MODEL=llama-3.3-70b-versatile

# Risk engine selector ("llm" or "rules"). Empty LLM_API_KEY -> auto-fallback to rules.
RISK_ENGINE=llm
RISK_AUTO_BLOCK_LEVEL=critical

# Legacy aliases (backward compatible). If you only set OPENAI_* the app still works.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
